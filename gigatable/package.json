{
  "name": "gigatable",
  "version": "1.0.0",
  "description": "Excel-like datatable for React — add it to your codebase with npx gigatable init",
  "bin": {
    "gigatable": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
